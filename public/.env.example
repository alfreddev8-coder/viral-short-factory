# ============================================
# ClipForge — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys
# All services have free tiers!

# Turso Database (https://turso.tech)
# Sign up → Create database → Copy URL + Token
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# Groq AI (https://console.groq.com)
# Sign up → API Keys → Create new key
GROQ_API_KEY=gsk_your_groq_api_key_here

# GitHub (for Actions automation pipeline)
# Settings → Developer settings → Personal access tokens → Generate
# Required scopes: repo, workflow
GH_TOKEN=ghp_your_github_personal_access_token
GH_OWNER=your-github-username
GH_REPO=clipforge
