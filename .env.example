# ============================================
# Viral Shorts Factory — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Turso Database (Edge SQLite)
# Get these from: turso db show <name> --url / turso db tokens create <name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Groq AI API Key
# Get from: https://console.groq.com/
GROQ_API_KEY=

# GitHub (for triggering automation workflows)
# Create a Personal Access Token at: https://github.com/settings/tokens
# Needs: repo + workflow scopes
GH_TOKEN=
GH_OWNER=
GH_REPO=
